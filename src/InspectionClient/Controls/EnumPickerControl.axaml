<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InspectionClient.Controls.EnumPickerControl"
             x:Name="Root">

  <Grid>

    <!-- ── 토글 버튼 ── -->
    <Button x:Name="ToggleButton"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            Click="OnToggleClicked">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   x:Name="SelectedLabel"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="▾"
                   VerticalAlignment="Center"
                   Margin="6,0,0,0" />
      </Grid>
    </Button>

    <!-- ── 드롭다운 패널 (Popup 없이 ZIndex로 오버레이) ── -->
    <Border x:Name="DropDownPanel"
            ZIndex="100"
            IsVisible="False"
            VerticalAlignment="Top"
            Margin="0,0,0,0"
            Background="{DynamicResource BgSurface}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1"
            CornerRadius="4"
            BoxShadow="0 4 12 0 #40000000">
      <ListBox x:Name="ItemList"
               SelectionChanged="OnSelectionChanged" />
    </Border>

  </Grid>

</UserControl>
