<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="400"
             x:Class="InspectionClient.Controls.SelectionListControl">

  <DockPanel>

    <!-- ── 헤더: 제목 + Refresh ──────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Padding="12,10"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   x:Name="HeaderTextBlock"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMuted}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                x:Name="RefreshButton"
                Padding="4" ToolTip.Tip="새로고침">
          <mi:MaterialIcon Kind="Refresh" Width="14" Height="14" />
        </Button>
      </Grid>
    </Border>

    <!-- ── 하단 액션 버튼 바 ────────────────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Padding="8,8"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,1,0,0">
      <Panel>

        <!-- 미선택 상태: Load -->
        <Button x:Name="LoadButton"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                ToolTip.Tip="선택 항목 불러오기">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Import" Width="12" Height="12" />
            <TextBlock Text="Load" FontSize="11" />
          </StackPanel>
        </Button>

        <!-- 로드 상태: Unload -->
        <Button x:Name="UnloadButton"
                IsVisible="False"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                ToolTip.Tip="선택 해제">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Close" Width="12" Height="12" />
            <TextBlock Text="Unload" FontSize="11" />
          </StackPanel>
        </Button>

      </Panel>
    </Border>

    <!-- ── 목록 ──────────────────────────────────────────────────────────── -->
    <ListBox x:Name="ItemListBox"
             Padding="4" />

  </DockPanel>

</UserControl>
