<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:InspectionClient.Controls"
             xmlns:pg="clr-namespace:Avalonia.PropertyGrid.Controls;assembly=Avalonia.PropertyGrid"
             xmlns:vm="using:InspectionClient.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="InspectionClient.Views.OpticSettingView"
             x:DataType="vm:OpticSettingViewModel">

  <Grid ColumnDefinitions="*,*">

    <!-- Left: Display -->
    <controls:DisplayControl Grid.Column="0"
                             Source="{Binding FrameImage}" />

    <!-- Right: 탭 패널 -->
    <Border Grid.Column="1"
            Background="{DynamicResource BgSurface}"
            BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1,0,0,0"
            Padding="8">

      <TabControl>

        <!-- ── Spec 탭 ── -->
        <TabItem Header="Spec">
          <DockPanel>
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,8,0,0">
              <Button Content="Restore" Command="{Binding RestoreCommand}" />
              <Button Content="Apply"   Command="{Binding ApplyCommand}" />
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="16">
                <pg:PropertyGrid DataContext="{Binding Spec}" />
                <pg:PropertyGrid DataContext="{Binding Settings}" />
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </TabItem>

        <!-- ── Fg 탭 ── -->
        <TabItem Header="Fg">
          <controls:FrameGrabberControlView DataContext="{Binding FgViewModel}" />
        </TabItem>

      </TabControl>

    </Border>

  </Grid>
</UserControl>
