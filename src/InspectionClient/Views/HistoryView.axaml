<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:ifaces="using:InspectionClient.Interfaces"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="InspectionClient.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

  <Grid ColumnDefinitions="300,1,*">

    <!-- ── 좌측: 검사 결과 목록 ──────────────────────────────────────── -->
    <DockPanel Grid.Column="0">

      <Border DockPanel.Dock="Top"
              Padding="12,10"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="RESULT LIST"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMuted}"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Command="{Binding RefreshResultListCommand}"
                  Padding="4" ToolTip.Tip="새로고침">
            <mi:MaterialIcon Kind="Refresh" Width="14" Height="14" />
          </Button>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Bottom"
              Padding="8,8"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="0,1,0,0">
        <Button HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Command="{Binding DeleteSelectedResultCommand}"
                ToolTip.Tip="선택 결과 삭제">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Delete" Width="12" Height="12" />
            <TextBlock Text="Delete" FontSize="11" />
          </StackPanel>
        </Button>
      </Border>

      <ListBox ItemsSource="{Binding ResultList}"
               SelectedItem="{Binding SelectedResult}"
               Padding="4">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="ifaces:InspectionResultEntry">
            <StackPanel Spacing="2" Margin="4,4">
              <TextBlock FontSize="12" FontWeight="SemiBold">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} | {1}">
                    <Binding Path="Result.RecipeName" />
                    <Binding Path="Result.Status" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock FontSize="10"
                         Foreground="{DynamicResource TextMuted}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:yyyy-MM-dd HH:mm}">
                    <Binding Path="Result.StartedAt" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

    </DockPanel>

    <!-- 구분선 -->
    <Border Grid.Column="1" Background="{DynamicResource BorderSubtle}" />

    <!-- ── 우측: 상세 영역 (추후 확장) ──────────────────────────────── -->
    <Border Grid.Column="2" Background="{DynamicResource BgBase}" />

  </Grid>
</UserControl>
