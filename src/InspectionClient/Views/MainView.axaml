<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:views="using:InspectionClient.Views"
             xmlns:controls="using:InspectionClient.Controls"
             xmlns:conv="using:InspectionClient.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="InspectionClient.Views.MainView"
             x:DataType="vm:MainViewModel">

  <DockPanel>

    <!-- ── Header ─────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Height="24"
            Background="{DynamicResource BgSurface}"
            BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
            Padding="16,0">
      <Grid ColumnDefinitions="*,Auto">

        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"
                   Text="{Binding TitleText}" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal" Spacing="20"
                    VerticalAlignment="Center">

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7"
                     Fill="{Binding IsFrameGrabberConnected,
                            Converter={x:Static conv:ConnectionStatusConverter.Instance}}"
                     VerticalAlignment="Center" />
            <TextBlock Text="Frame Grabber"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="12" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7"
                     Fill="{Binding IsInspectionConnected,
                            Converter={x:Static conv:ConnectionStatusConverter.Instance}}"
                     VerticalAlignment="Center" />
            <TextBlock Text="Inspection"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="12" VerticalAlignment="Center" />
          </StackPanel>

        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Log Panel ──────────────────────────────────────── -->
    <controls:LogControl DockPanel.Dock="Bottom"
                         Height="160"
                         Entries="{Binding Log.Entries}" />

    <!-- ── Main Content ───────────────────────────────────── -->
    <Grid ColumnDefinitions="48,*" ClipToBounds="False">

      <!-- Left Navigation Panel -->
      <Border Grid.Column="0"
              Background="{DynamicResource BgSurface}"
              BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
              ZIndex="10" ClipToBounds="False">

        <StackPanel VerticalAlignment="Top" Spacing="2" Margin="0,8,0,0">

          <!-- Setup -->
          <Button Name="NavSetup" Classes="nav-item active"
                  Command="{Binding NavigateCommand}" CommandParameter="Setup"
                  PointerEntered="OnNavPointerEntered" PointerExited="OnNavPointerExited"
                  ToolTip.Tip="Setup" ToolTip.Placement="Right">
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="TuneVariant" />
            </Grid>
          </Button>

          <!-- Inspection -->
          <Button Name="NavInspection" Classes="nav-item"
                  Command="{Binding NavigateCommand}" CommandParameter="Inspection"
                  PointerEntered="OnNavPointerEntered" PointerExited="OnNavPointerExited"
                  ToolTip.Tip="Inspection" ToolTip.Placement="Right">
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="Magnify" />
            </Grid>
          </Button>

          <!-- History -->
          <Button Name="NavHistory" Classes="nav-item"
                  Command="{Binding NavigateCommand}" CommandParameter="History"
                  PointerEntered="OnNavPointerEntered" PointerExited="OnNavPointerExited"
                  ToolTip.Tip="History" ToolTip.Placement="Right">
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="History" />
            </Grid>
          </Button>

          <!-- Divider -->
          <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="10,4" />

          <!-- Frame Grabber -->
          <Button Name="NavFrameGrabber" Classes="nav-item"
                  Command="{Binding NavigateCommand}" CommandParameter="FrameGrabber"
                  PointerEntered="OnNavPointerEntered" PointerExited="OnNavPointerExited"
                  ToolTip.Tip="Frame Grabber" ToolTip.Placement="Right">
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="Tune" />
            </Grid>
          </Button>

          <!-- Equipment Spec -->
          <Button Name="NavEquipmentSpec" Classes="nav-item"
                  Command="{Binding NavigateCommand}" CommandParameter="EquipmentSpec"
                  PointerEntered="OnNavPointerEntered" PointerExited="OnNavPointerExited"
                  ToolTip.Tip="Equipment Spec" ToolTip.Placement="Right">
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="InformationOutline" />
            </Grid>
          </Button>

          <!-- App Setting -->
          <Button Name="NavAppSetting" Classes="nav-item"
                  Command="{Binding NavigateCommand}" CommandParameter="AppSetting"
                  PointerEntered="OnNavPointerEntered" PointerExited="OnNavPointerExited"
                  ToolTip.Tip="App Setting" ToolTip.Placement="Right">
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="CogOutline" />
            </Grid>
          </Button>

        </StackPanel>
      </Border>

      <!-- View Content Area -->
      <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="vm:InspectionWorkflowViewModel">
            <views:InspectionWorkflowView />
          </DataTemplate>
          <DataTemplate DataType="vm:SetupWorkflowViewModel">
            <views:SetupWorkflowView />
          </DataTemplate>
          <DataTemplate DataType="vm:HistoryViewModel">
            <views:HistoryView />
          </DataTemplate>
          <DataTemplate DataType="vm:FrameGrabberViewModelBase">
            <views:FrameGrabberView />
          </DataTemplate>
          <DataTemplate DataType="vm:EquipmentSpecViewModel">
            <views:EquipmentSpecView />
          </DataTemplate>
          <DataTemplate DataType="vm:AppSettingViewModel">
            <views:AppSettingView />
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

    </Grid>

  </DockPanel>
</UserControl>
