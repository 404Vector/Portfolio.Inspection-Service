<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:controls="using:InspectionClient.Controls"
             xmlns:clientModels="using:InspectionClient.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="InspectionClient.Views.InspectionWorkflowView"
             x:DataType="vm:InspectionWorkflowViewModel">

  <Grid ColumnDefinitions="240,1,240,1,*">

    <!-- ── Recipe 목록 ──────────────────────────────────────────────── -->
    <controls:SelectionListControl
        Grid.Column="0"
        Header="RECIPE LIST"
        ItemsSource="{Binding RecipeList}"
        SelectedItem="{Binding SelectedRecipe}"
        LoadedItem="{Binding LoadedRecipe}"
        LoadCommand="{Binding LoadSelectedRecipeCommand}"
        UnloadCommand="{Binding UnloadRecipeCommand}"
        RefreshCommand="{Binding RefreshRecipeListCommand}">
      <controls:SelectionListControl.ItemTemplate>
        <DataTemplate x:DataType="clientModels:RecipeRow">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,4">
            <TextBlock Text="{Binding Id}"
                       FontSize="10" MinWidth="24"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding Recipe.RecipeName}"
                       FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
          </StackPanel>
        </DataTemplate>
      </controls:SelectionListControl.ItemTemplate>
    </controls:SelectionListControl>

    <!-- 구분선 -->
    <Border Grid.Column="1" Background="{DynamicResource BorderSubtle}" />

    <!-- ── Wafer 목록 ───────────────────────────────────────────────── -->
    <controls:SelectionListControl
        Grid.Column="2"
        Header="WAFER LIST"
        ItemsSource="{Binding WaferList}"
        SelectedItem="{Binding SelectedWafer}"
        LoadedItem="{Binding LoadedWafer}"
        LoadCommand="{Binding LoadSelectedWaferCommand}"
        UnloadCommand="{Binding UnloadWaferCommand}"
        RefreshCommand="{Binding RefreshWaferListCommand}">
      <controls:SelectionListControl.ItemTemplate>
        <DataTemplate x:DataType="clientModels:WaferInfoRow">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,4">
            <TextBlock Text="{Binding Id}"
                       FontSize="10" MinWidth="24"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}"
                       FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
          </StackPanel>
        </DataTemplate>
      </controls:SelectionListControl.ItemTemplate>
    </controls:SelectionListControl>

    <!-- 구분선 -->
    <Border Grid.Column="3" Background="{DynamicResource BorderSubtle}" />

    <!-- ── 우측: 검사 메인 영역 ─────────────────────────────────────── -->
    <DockPanel Grid.Column="4">

      <!-- ── 상단 툴바 ──────────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top"
              Padding="16,10"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto">

          <!-- Recipe / Wafer 요약 -->
          <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="FileDocumentOutline" Width="14" Height="14"
                               Foreground="{DynamicResource TextMuted}" />
              <TextBlock Text="{Binding RecipeSummary}"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondary}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="CircleOutline" Width="14" Height="14"
                               Foreground="{DynamicResource TextMuted}" />
              <TextBlock Text="{Binding WaferSummary}"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondary}" />
            </StackPanel>
          </StackPanel>

          <!-- 버튼 -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding StopCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="Stop" Width="14" Height="14" />
                <TextBlock Text="Stop" />
              </StackPanel>
            </Button>
            <Button Classes="accent" Command="{Binding StartCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="Play" Width="14" Height="14" />
                <TextBlock Text="Start" />
              </StackPanel>
            </Button>
          </StackPanel>

        </Grid>
      </Border>

      <!-- ── 하단: 진행 바 ──────────────────────────────────────────────── -->
      <Border DockPanel.Dock="Bottom"
              Padding="16,8"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="*,12,120">
          <ProgressBar Grid.Column="0"
                       Value="{Binding ProgressRatio}"
                       Minimum="0" Maximum="1"
                       Height="6" />
          <TextBlock Grid.Column="2"
                     Text="{Binding ProgressText}"
                     FontSize="11"
                     Foreground="{DynamicResource TextMuted}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right" />
        </Grid>
      </Border>

      <!-- ── 중앙: WaferMap ─────────────────────────────────────────────── -->
      <controls:WaferMapControl
          DieMap="{Binding DieMap}"
          DieStatuses="{Binding DieStatuses}" />

    </DockPanel>

  </Grid>

</UserControl>
