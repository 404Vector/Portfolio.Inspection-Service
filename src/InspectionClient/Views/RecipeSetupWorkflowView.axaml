<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:models="using:InspectionClient.Models"
             xmlns:controls="using:InspectionClient.Controls"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="InspectionClient.Views.RecipeSetupWorkflowView"
             x:DataType="vm:RecipeSetupWorkflowViewModel">

  <Grid ColumnDefinitions="240,1,*">

    <!-- ── 좌측: 목록 패널 ────────────────────────────────────────────── -->
    <DockPanel Grid.Column="0">

      <!-- WaferInfo 목록 (선택 전용) -->
      <controls:DbTableControl DockPanel.Dock="Top"
                               Height="240"
                               Header="WAFER LIST"
                               ItemsSource="{Binding WaferTableVm.Items}"
                               SelectedItem="{Binding WaferTableVm.SelectedItem}"
                               LoadCommand="{Binding WaferTableVm.LoadCommand}"
                               RefreshCommand="{Binding WaferTableVm.RefreshCommand}">
        <controls:DbTableControl.ItemTemplate>
          <DataTemplate x:DataType="models:WaferInfoRow">
            <StackPanel Spacing="2" Margin="4,4">
              <TextBlock Text="{Binding Name}"
                         FontSize="12" FontWeight="SemiBold" />
              <TextBlock FontSize="10"
                         Foreground="{DynamicResource TextMuted}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} | {1}">
                    <Binding Path="Info.WaferType" />
                    <Binding Path="Info.LotId" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </controls:DbTableControl.ItemTemplate>
      </controls:DbTableControl>

      <!-- Wafer 선택 버튼 -->
      <Border DockPanel.Dock="Top"
              Padding="8,8"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="0,1,0,1">
        <Button HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Command="{Binding SelectWaferInfoCommand}"
                ToolTip.Tip="선택한 Wafer를 Recipe에 연결">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="LinkVariant" Width="12" Height="12" />
            <TextBlock Text="Wafer 선택" FontSize="11" />
          </StackPanel>
        </Button>
      </Border>

      <!-- Recipe 목록 -->
      <controls:DbTableControl Header="RECIPE LIST"
                               ItemsSource="{Binding Items}"
                               SelectedItem="{Binding SelectedItem}"
                               LoadedItem="{Binding LoadedItem, Mode=TwoWay}"
                               LoadCommand="{Binding LoadCommand}"
                               CreateCommand="{Binding CreateCommand}"
                               DeleteCommand="{Binding DeleteCommand}"
                               SaveCommand="{Binding SaveCommand}"
                               CancelCommand="{Binding CancelCommand}"
                               RefreshCommand="{Binding RefreshCommand}">
        <controls:DbTableControl.ItemTemplate>
          <DataTemplate x:DataType="models:RecipeRow">
            <StackPanel Spacing="2" Margin="4,4">
              <TextBlock Text="{Binding Name}"
                         FontSize="12" FontWeight="SemiBold" />
              <TextBlock FontSize="10"
                         Foreground="{DynamicResource TextMuted}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}FOV {0:0}×{1:0} μm">
                    <Binding Path="Recipe.Fov.WidthUm" />
                    <Binding Path="Recipe.Fov.HeightUm" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </controls:DbTableControl.ItemTemplate>
      </controls:DbTableControl>

    </DockPanel>

    <!-- 구분선 -->
    <Border Grid.Column="1" Background="{DynamicResource BorderSubtle}" />

    <!-- ── 우측: 파라미터 폼 ──────────────────────────────────────────── -->
    <ScrollViewer Grid.Column="2"
                  IsEnabled="{Binding LoadedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Padding="24,16"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel MaxWidth="640" Spacing="20">

        <!-- 섹션: Wafer Info -->
        <StackPanel Spacing="8">
          <TextBlock Text="WAFER INFO"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMuted}" />
          <Border Background="{DynamicResource BgSurface}"
                  BorderBrush="{DynamicResource BorderSubtle}"
                  BorderThickness="1" CornerRadius="4" Padding="12,8">
            <TextBlock Text="{Binding WaferSummary}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" />
          </Border>
        </StackPanel>

        <Border Height="1" Background="{DynamicResource BorderSubtle}" />

        <!-- 섹션: Recipe Identity -->
        <TextBlock Text="RECIPE"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMuted}" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Recipe Name" Classes="form-label" />
          <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding RecipeName}" FontSize="12" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Description"
                     Classes="form-label" Margin="0,8,0,0" />
          <TextBox   Grid.Row="1" Grid.Column="1"
                     Text="{Binding Description}" FontSize="12" Margin="0,8,0,0" />
        </Grid>

        <Border Height="1" Background="{DynamicResource BorderSubtle}" />

        <!-- 섹션: FOV -->
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="FOV"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Command="{Binding RecalculateFovFromEquipmentCommand}"
                    FontSize="11">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <mi:MaterialIcon Kind="Calculator" Width="12" Height="12" />
                <TextBlock Text="장비 설정에서 계산" />
              </StackPanel>
            </Button>
          </Grid>

          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (μm)" Classes="form-label" />
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           Value="{Binding FovWidthUm}"
                           Minimum="1" Maximum="100000" Increment="10" FormatString="0.##"
                           FontSize="12" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Height (μm)"
                       Classes="form-label" Margin="0,8,0,0" />
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           Value="{Binding FovHeightUm}"
                           Minimum="1" Maximum="100000" Increment="10" FormatString="0.##"
                           FontSize="12" Margin="0,8,0,0" />
          </Grid>
        </StackPanel>

        <Border Height="1" Background="{DynamicResource BorderSubtle}" />

        <!-- 섹션: Scan Options -->
        <TextBlock Text="SCAN OPTIONS"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMuted}" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Overlap X (μm)" Classes="form-label" />
          <NumericUpDown Grid.Row="0" Grid.Column="1"
                         Value="{Binding OverlapXum}"
                         Minimum="0" Maximum="10000" Increment="10" FormatString="0.#"
                         FontSize="12" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Overlap Y (μm)"
                     Classes="form-label" Margin="0,8,0,0" />
          <NumericUpDown Grid.Row="1" Grid.Column="1"
                         Value="{Binding OverlapYum}"
                         Minimum="0" Maximum="10000" Increment="10" FormatString="0.#"
                         FontSize="12" Margin="0,8,0,0" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Stop on First Fail"
                     Classes="form-label" Margin="0,8,0,0" />
          <ToggleSwitch Grid.Row="2" Grid.Column="1"
                        IsChecked="{Binding StopOnFirstFail}"
                        OnContent="" OffContent="" Margin="0,8,0,0" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Max Frames (0=∞)"
                     Classes="form-label" Margin="0,8,0,0" />
          <NumericUpDown Grid.Row="3" Grid.Column="1"
                         Value="{Binding MaxFrameCount}"
                         Minimum="0" Maximum="100000" Increment="100" FormatString="0"
                         FontSize="12" Margin="0,8,0,0" />
        </Grid>

      </StackPanel>
    </ScrollViewer>

  </Grid>

  <UserControl.Styles>
    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

</UserControl>
