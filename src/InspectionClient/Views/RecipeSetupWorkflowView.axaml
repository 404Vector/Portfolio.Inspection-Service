<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:views="using:InspectionClient.Views"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="InspectionClient.Views.RecipeSetupWorkflowView"
             x:DataType="vm:RecipeSetupWorkflowViewModel">

  <TabControl Classes="tab-underline">

    <TabItem Header="Wafer Surface">
      <views:WaferSurfaceRecipeSetupView DataContext="{Binding WaferSurface}" />
    </TabItem>

    <TabItem Header="Die Spot">
      <views:DieSpotRecipeSetupView DataContext="{Binding DieSpot}" />
    </TabItem>

  </TabControl>

</UserControl>
