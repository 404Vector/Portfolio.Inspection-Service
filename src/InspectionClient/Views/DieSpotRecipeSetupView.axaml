<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:models="using:InspectionClient.Models"
             xmlns:controls="using:InspectionClient.Controls"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="InspectionClient.Views.DieSpotRecipeSetupView"
             x:DataType="vm:DieSpotRecipeWorkflowViewModel">

  <Grid ColumnDefinitions="240,1,*">

    <!-- ── 좌측: Recipe 목록 패널 ──────────────────────────────────────── -->
    <controls:DbTableControl Grid.Column="0"
                             Header="RECIPE LIST"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem}"
                             LoadedItem="{Binding LoadedItem, Mode=TwoWay}"
                             LoadCommand="{Binding LoadCommand}"
                             CreateCommand="{Binding CreateCommand}"
                             DeleteCommand="{Binding DeleteCommand}"
                             SaveCommand="{Binding SaveCommand}"
                             CancelCommand="{Binding CancelCommand}"
                             RefreshCommand="{Binding RefreshCommand}">
      <controls:DbTableControl.ItemTemplate>
        <DataTemplate x:DataType="models:DieSpotRecipeRow">
          <StackPanel Spacing="2" Margin="4,4">
            <Grid ColumnDefinitions="Auto,8,*">
              <TextBlock Grid.Column="0" Text="{Binding Id}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMuted}" />
              <TextBlock Grid.Column="2" Text="{Binding Recipe.RecipeName}"
                         FontSize="12" FontWeight="SemiBold" />
            </Grid>
          </StackPanel>
        </DataTemplate>
      </controls:DbTableControl.ItemTemplate>
    </controls:DbTableControl>

    <!-- 구분선 -->
    <Border Grid.Column="1" Background="{DynamicResource BorderSubtle}" />

    <!-- ── 우측: 파라미터 폼 + 보조편집패널 ──────────────────────────── -->
    <Grid Grid.Column="2"
          ColumnDefinitions="*,Auto"
          VerticalAlignment="Stretch"
          IsEnabled="{Binding LoadedItem, Converter={x:Static ObjectConverters.IsNotNull}}">

      <!-- ── 메인 편집 패널 ──────────────────────────────────────────── -->
      <ScrollViewer Grid.Column="0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" Spacing="20" Margin="24,16">

          <!-- 섹션: Recipe Identity -->
          <TextBlock Text="RECIPE" Classes="section-header" />

          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Recipe Name" Classes="form-label" />
            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding RecipeName}" FontSize="12" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description"
                       Classes="form-label" Margin="0,8,0,0" />
            <TextBox   Grid.Row="1" Grid.Column="1"
                       Text="{Binding Description}" FontSize="12" Margin="0,8,0,0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtle}" />

          <!-- 섹션: FOV -->
          <TextBlock Text="FOV" Classes="section-header" />

          <Grid ColumnDefinitions="160,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">

            <!-- Width -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (μm)" Classes="form-label" />
            <Border    Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Classes="value-display">
              <TextBlock Text="{Binding FovWidthUm, StringFormat={}{0:0.##}}" Classes="value-text" />
            </Border>

            <!-- Height -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Height (μm)"
                       Classes="form-label" Margin="0,8,0,0" />
            <Border    Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Classes="value-display" Margin="0,8,0,0">
              <TextBlock Text="{Binding FovHeightUm, StringFormat={}{0:0.##}}" Classes="value-text" />
            </Border>

            <!-- Magnification -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Magnification (×)"
                       Classes="form-label" Margin="0,8,0,0" />
            <Border    Grid.Row="2" Grid.Column="1" Classes="value-display" Margin="0,8,0,0">
              <TextBlock Text="{Binding SelectedMagnification, StringFormat={}{0}×}" Classes="value-text" />
            </Border>
            <Button    Grid.Row="2" Grid.Column="2"
                       Command="{Binding OpenMagnificationPanelCommand}"
                       Classes="edit-btn" Margin="0,8,0,0" ToolTip.Tip="배율 선택">
              <mi:MaterialIcon Kind="ChevronRight" Width="14" Height="14" />
            </Button>

            <!-- Pixel Resolution -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Pixel Resolution (μm/px)"
                       Classes="form-label" Margin="0,8,0,0" />
            <Border    Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Classes="value-display" Margin="0,8,0,0">
              <TextBlock Text="{Binding PixelResolutionUm, StringFormat={}{0:0.####}}" Classes="value-text" />
            </Border>

          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtle}" />

          <!-- 섹션: Shot Center -->
          <TextBlock Text="SHOT CENTER" Classes="section-header" />

          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">

            <!-- Shot Center X -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="X (μm)" Classes="form-label" />
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           Value="{Binding ShotCenterXum}"
                           Minimum="-200000" Maximum="200000" Increment="100" FormatString="0.##"
                           FontSize="12" />

            <!-- Shot Center Y -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y (μm)"
                       Classes="form-label" Margin="0,8,0,0" />
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           Value="{Binding ShotCenterYum}"
                           Minimum="-200000" Maximum="200000" Increment="100" FormatString="0.##"
                           FontSize="12" Margin="0,8,0,0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtle}" />

          <!-- 섹션: Inspection Options -->
          <TextBlock Text="INSPECTION OPTIONS" Classes="section-header" />

          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">

            <!-- Threshold -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Threshold (0~1)" Classes="form-label" />
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           Value="{Binding Threshold}"
                           Minimum="0" Maximum="1" Increment="0.05" FormatString="0.##"
                           FontSize="12" />

            <!-- Save on Fail -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Save on Fail"
                       Classes="form-label" Margin="0,8,0,0" />
            <ToggleSwitch Grid.Row="1" Grid.Column="1"
                          IsChecked="{Binding SaveOnFail}"
                          OnContent="" OffContent="" Margin="0,8,0,0" />
          </Grid>

        </StackPanel>
      </ScrollViewer>

      <!-- ── 보조편집패널 ─────────────────────────────────────────────── -->
      <Border Grid.Column="1"
              IsVisible="{Binding IsMagnificationPanelVisible}"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="1,0,0,0"
              Width="200">
        <DockPanel>

          <!-- 헤더 -->
          <Border DockPanel.Dock="Top"
                  Padding="12,10"
                  BorderBrush="{DynamicResource BorderSubtle}"
                  BorderThickness="0,0,0,1">
            <TextBlock Text="MAGNIFICATION"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
          </Border>

          <!-- 배율 선택 리스트 -->
          <ItemsControl Padding="4"
                        ItemsSource="{Binding AvailableMagnifications}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Classes="side-item"
                        Command="{Binding $parent[UserControl].((vm:DieSpotRecipeWorkflowViewModel)DataContext).SelectMagnificationCommand}"
                        CommandParameter="{Binding}">
                  <TextBlock FontSize="13">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0}×">
                        <Binding />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </DockPanel>
      </Border>

    </Grid>

  </Grid>

  <UserControl.Styles>
    <Style Selector="TextBlock.section-header">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>
    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.value-display">
      <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.value-text">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.edit-btn">
      <Setter Property="Padding" Value="4" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.side-item">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </UserControl.Styles>

</UserControl>
