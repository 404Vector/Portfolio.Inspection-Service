<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:models="using:InspectionClient.Models"
             xmlns:controls="using:InspectionClient.Controls"
             xmlns:converters="using:InspectionClient.Converters"
             x:Class="InspectionClient.Views.FrameGrabberView"
             x:DataType="vm:VirtualFrameGrabberViewModel">

  <UserControl.Resources>
    <converters:BoolToTextConverter x:Key="ScanSourceButtonConverter"
                                    TrueText="Cancel"
                                    FalseText="Setting" />
  </UserControl.Resources>

  <Grid ColumnDefinitions="*,*">

    <!-- ── 좌측: 프레임 디스플레이 ── -->
    <controls:DisplayControl Grid.Column="0"
                             Source="{Binding FrameImage}" />

    <!-- ── 우측: 파라미터 제어 ── -->
    <DockPanel Grid.Column="1" Margin="8,0,0,0"
               IsEnabled="{Binding IsConnected}">

      <!-- ── 하단: 획득 제어 + Apply / Restore ── -->
      <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0"
            ColumnDefinitions="*,Auto">

        <!-- 획득 제어 -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button Content="Start"
                  Command="{Binding StartAcquisitionCommand}"
                  IsEnabled="{Binding !IsAcquisitionRunning}" />
          <Button Content="Stop"
                  Command="{Binding StopAcquisitionCommand}"
                  IsEnabled="{Binding IsAcquisitionRunning}" />
          <Button Content="Trigger"
                  Command="{Binding TriggerFrameCommand}" />
        </StackPanel>

        <!-- 파라미터 Apply / Restore -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    IsEnabled="{Binding !IsAcquisitionRunning}">
          <Button Content="Restore" Command="{Binding RestoreCommand}" />
          <Button Content="Apply"   Command="{Binding ApplyCommand}" />
        </StackPanel>

      </Grid>

      <!-- ── 상태 메시지 ── -->
      <TextBlock DockPanel.Dock="Top"
                 Text="{Binding StatusMessage}"
                 Foreground="{DynamicResource TextMuted}"
                 FontSize="12"
                 Margin="0,0,0,8"
                 IsVisible="{Binding StatusMessage,
                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    IsEnabled="{Binding !IsAcquisitionRunning}">
        <StackPanel>

          <!-- ── 파라미터 목록 ── -->
          <ItemsControl ItemsSource="{Binding Parameters}">
            <ItemsControl.ItemTemplate>
              <controls:ParameterDataTemplateSelector>

                <!-- Int64 -->
                <controls:ParameterDataTemplateSelector.Int64Template>
                  <DataTemplate DataType="models:GrabberParameterItem">
                    <Grid ColumnDefinitions="*,*" Margin="0,2">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" />
                      <NumericUpDown Grid.Column="1"
                                     Value="{Binding CurrentValue}"
                                     Minimum="{Binding MinValue}"
                                     Maximum="{Binding MaxValue}"
                                     Increment="1"
                                     FormatString="0"
                                     FontSize="13" />
                    </Grid>
                  </DataTemplate>
                </controls:ParameterDataTemplateSelector.Int64Template>

                <!-- Double -->
                <controls:ParameterDataTemplateSelector.DoubleTemplate>
                  <DataTemplate DataType="models:GrabberParameterItem">
                    <Grid ColumnDefinitions="*,*" Margin="0,2">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" />
                      <NumericUpDown Grid.Column="1"
                                     Value="{Binding CurrentValue}"
                                     Minimum="{Binding MinValue}"
                                     Maximum="{Binding MaxValue}"
                                     Increment="0.01"
                                     FormatString="0.##"
                                     FontSize="13" />
                    </Grid>
                  </DataTemplate>
                </controls:ParameterDataTemplateSelector.DoubleTemplate>

                <!-- Bool -->
                <controls:ParameterDataTemplateSelector.BoolTemplate>
                  <DataTemplate DataType="models:GrabberParameterItem">
                    <Grid ColumnDefinitions="*,*" Margin="0,2">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" />
                      <ToggleSwitch Grid.Column="1"
                                    IsChecked="{Binding CurrentValue}"
                                    OffContent="Off" OnContent="On"
                                    FontSize="13" />
                    </Grid>
                  </DataTemplate>
                </controls:ParameterDataTemplateSelector.BoolTemplate>

                <!-- Enum (AllowedValues가 있는 String) -->
                <controls:ParameterDataTemplateSelector.EnumTemplate>
                  <DataTemplate DataType="models:GrabberParameterItem">
                    <Grid ColumnDefinitions="*,*" Margin="0,2">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" />
                      <controls:EnumPickerControl Grid.Column="1"
                                                   ItemsSource="{Binding AllowedValues}"
                                                   SelectedItem="{Binding CurrentValue}"
                                                   FontSize="13" />
                    </Grid>
                  </DataTemplate>
                </controls:ParameterDataTemplateSelector.EnumTemplate>

                <!-- Bytes (file picker) -->
                <controls:ParameterDataTemplateSelector.BytesTemplate>
                  <DataTemplate DataType="models:GrabberParameterItem">
                    <Grid ColumnDefinitions="*,*" Margin="0,2">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" />
                      <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding CurrentValue}"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,4,0" />
                        <Button Grid.Column="1"
                                Content="Browse"
                                Command="{Binding $parent[ItemsControl].((vm:FrameGrabberViewModelBase)DataContext).BrowseFileCommand}"
                                CommandParameter="{Binding}"
                                FontSize="13" />
                      </Grid>
                    </Grid>
                  </DataTemplate>
                </controls:ParameterDataTemplateSelector.BytesTemplate>

                <!-- String (fallback) -->
                <controls:ParameterDataTemplateSelector.StringTemplate>
                  <DataTemplate DataType="models:GrabberParameterItem">
                    <Grid ColumnDefinitions="*,*" Margin="0,2">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" />
                      <TextBox Grid.Column="1"
                               Text="{Binding CurrentValue}"
                               FontSize="13" />
                    </Grid>
                  </DataTemplate>
                </controls:ParameterDataTemplateSelector.StringTemplate>

              </controls:ParameterDataTemplateSelector>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- ── Scan Source 설정 ── -->
          <Border Margin="0,8,0,0"
                  Padding="0,4"
                  BorderBrush="{DynamicResource BorderSubtle}"
                  BorderThickness="0,1,0,0">

            <!-- Scan Source 헤더: 라벨 + Setting/Cancel 버튼 -->
            <StackPanel>
              <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                <TextBlock Grid.Column="0"
                           Text="Scan Source"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="{Binding IsScanSourceSettingOpen,
                                 Converter={StaticResource ScanSourceButtonConverter}}"
                        Command="{Binding ToggleScanSourceSettingCommand}"
                        FontSize="13"
                        MinWidth="70" />
              </Grid>

              <!-- Wafer/Recipe 선택 패널 (Setting 열림 시 표시) -->
              <StackPanel IsVisible="{Binding IsScanSourceSettingOpen}"
                          Margin="0,4,0,0">

                <Grid ColumnDefinitions="*,*" Height="200">
                  <!-- 좌: Wafer 선택 -->
                  <controls:SelectionListControl Grid.Column="0"
                      Header="WAFER"
                      ItemsSource="{Binding WaferList}"
                      SelectedItem="{Binding SelectedWafer}"
                      LoadedItem="{Binding LoadedWafer}"
                      RefreshCommand="{Binding RefreshWafersCommand}"
                      Margin="0,0,4,0">
                    <controls:SelectionListControl.ItemTemplate>
                      <DataTemplate DataType="models:WaferInfoRow">
                        <TextBlock Text="{Binding Name}" FontSize="12" />
                      </DataTemplate>
                    </controls:SelectionListControl.ItemTemplate>
                  </controls:SelectionListControl>

                  <!-- 우: Recipe 선택 -->
                  <controls:SelectionListControl Grid.Column="1"
                      Header="RECIPE"
                      ItemsSource="{Binding RecipeList}"
                      SelectedItem="{Binding SelectedRecipe}"
                      LoadedItem="{Binding LoadedRecipe}"
                      RefreshCommand="{Binding RefreshRecipesCommand}"
                      Margin="4,0,0,0">
                    <controls:SelectionListControl.ItemTemplate>
                      <DataTemplate DataType="models:RecipeRow">
                        <TextBlock Text="{Binding Recipe.RecipeName}" FontSize="12" />
                      </DataTemplate>
                    </controls:SelectionListControl.ItemTemplate>
                  </controls:SelectionListControl>
                </Grid>

                <!-- Generate 버튼 -->
                <Button Content="Generate"
                        Command="{Binding GenerateCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,8,0,0"
                        FontSize="13" />

              </StackPanel>

            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

    </DockPanel>

  </Grid>

</UserControl>
