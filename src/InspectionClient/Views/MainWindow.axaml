<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="InspectionClient.Views.MainWindow"
        Title="Inspection Client"
        MinWidth="800" MinHeight="600"
        Background="{DynamicResource BgBase}">

  <DockPanel>

    <!-- ── Header ─────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Height="52"
            Background="{DynamicResource BgSurface}"
            BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
            Padding="16,0">
      <Grid ColumnDefinitions="*,Auto">

        <TextBlock Grid.Column="0"
                   Text="Inspection Client"
                   VerticalAlignment="Center"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal" Spacing="20"
                    VerticalAlignment="Center">

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7"
                     Fill="{DynamicResource StatusOffline}"
                     VerticalAlignment="Center" />
            <TextBlock Text="Frame Grabber"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="12" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7"
                     Fill="{DynamicResource StatusOffline}"
                     VerticalAlignment="Center" />
            <TextBlock Text="Inspection"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="12" VerticalAlignment="Center" />
          </StackPanel>

        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Log Panel ──────────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Height="160"
            Background="{DynamicResource BgLog}"
            BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
            Padding="12,8">
      <Grid RowDefinitions="Auto,*">

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
          <mi:MaterialIcon Kind="TextBoxOutline" Width="14" Height="14"
                           Foreground="{DynamicResource TextMuted}" />
          <TextBlock Text="LOG"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMuted}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource BgLogInner}"
                CornerRadius="4" Padding="10,8">
          <TextBlock Foreground="{DynamicResource TextMuted}"
                     FontFamily="Consolas,Menlo,Monospace"
                     FontSize="12"
                     VerticalAlignment="Top" />
        </Border>

      </Grid>
    </Border>

    <!-- ── Main Content ───────────────────────────────────── -->
    <Grid ColumnDefinitions="48,*" ClipToBounds="False">

      <!-- Left Navigation Panel -->
      <Border Grid.Column="0"
              Background="{DynamicResource BgSurface}"
              BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
              ZIndex="10" ClipToBounds="False">

        <StackPanel VerticalAlignment="Top" Spacing="2" Margin="0,8,0,0">

          <!-- Inspection -->
          <Button Name="NavInspection" Classes="nav-item active" Click="OnNavClick"
                  ToolTip.Tip="Inspection" ToolTip.Placement="Right"                   >
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="Magnify" />
            </Grid>
          </Button>

          <!-- History -->
          <Button Name="NavHistory" Classes="nav-item" Click="OnNavClick"
                  ToolTip.Tip="History" ToolTip.Placement="Right"                   >
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="History" />
            </Grid>
          </Button>

          <!-- Divider -->
          <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="10,4" />

          <!-- Optic Setting -->
          <Button Name="NavOpticSetting" Classes="nav-item" Click="OnNavClick"
                  ToolTip.Tip="Optic Setting" ToolTip.Placement="Right"                   >
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="Tune" />
            </Grid>
          </Button>

          <!-- App Setting -->
          <Button Name="NavAppSetting" Classes="nav-item" Click="OnNavClick"
                  ToolTip.Tip="App Setting" ToolTip.Placement="Right"                   >
            <Grid Width="48" Height="48">
              <Rectangle Classes="nav-accent" />
              <mi:MaterialIcon Kind="CogOutline" />
            </Grid>
          </Button>

        </StackPanel>
      </Border>

      <!-- View Content Area -->
      <ContentControl Name="MainContent" Grid.Column="1" />

    </Grid>

  </DockPanel>
</Window>
