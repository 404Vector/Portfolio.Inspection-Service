<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:InspectionClient.ViewModels"
        xmlns:views="using:InspectionClient.Views"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="InspectionClient.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Inspection Client"
        MinWidth="800" MinHeight="600"
        Background="{DynamicResource BgBase}">

  <views:MainView />

</Window>
