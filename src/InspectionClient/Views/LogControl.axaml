<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:vm="using:InspectionClient.ViewModels"
             xmlns:models="using:InspectionClient.Models"
             xmlns:conv="using:InspectionClient.Converters"
             x:Class="InspectionClient.Views.LogControl"
             x:DataType="vm:LogViewModel">

  <UserControl.Resources>
    <conv:LogLevelToForegroundConverter x:Key="LevelToFg" />
  </UserControl.Resources>

  <Border Background="{DynamicResource BgLog}"
          BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
          Padding="12,8">
    <Grid RowDefinitions="Auto,*">

      <!-- ── Header ────────────────────────────────────── -->
      <StackPanel Grid.Row="0"
                  Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
        <mi:MaterialIcon Kind="TextBoxOutline" Width="14" Height="14"
                         Foreground="{DynamicResource TextMuted}" />
        <TextBlock Text="LOG"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMuted}"
                   VerticalAlignment="Center" />
        <Button Command="{Binding ClearCommand}"
                Padding="6,1" FontSize="10"
                Foreground="{DynamicResource TextMuted}">
          Clear
        </Button>
      </StackPanel>

      <!-- ── Log Entries ───────────────────────────────── -->
      <Border Grid.Row="1"
              Background="{DynamicResource BgLogInner}"
              CornerRadius="4" Padding="10,8">
        <ScrollViewer x:Name="LogScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Entries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:LogEntry">
                <TextBlock Text="{Binding Display}"
                           FontFamily="Consolas,Menlo,Monospace"
                           FontSize="12"
                           Foreground="{Binding Level,
                                        Converter={StaticResource LevelToFg}}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

    </Grid>
  </Border>

</UserControl>
