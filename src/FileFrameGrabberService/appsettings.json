{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "RingBuffer": {
    "Name": "fgs_ringbuffer",
    "SlotCount": 8,
    "SlotDataSize": "1024 * 1024 * 3 * 8"
  }
}